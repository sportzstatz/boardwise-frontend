{
  "name": "boardwise-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12 <25"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contracts": "playwright test -c playwright.contract.config.js --project=api-contract --project=dom-contract",
    "test:contracts:api": "playwright test -c playwright.contract.config.js --project=api-contract",
    "test:contracts:dom": "playwright test -c playwright.contract.config.js --project=dom-contract",
    "test:contracts:candidate": "playwright test -c playwright.contract.config.js --project=api-contract --project=dom-contract --project=candidate-access",
    "test:contracts:access": "playwright test -c playwright.contract.config.js --project=candidate-access",
    "test:contracts:headed": "playwright test -c playwright.contract.config.js --project=api-contract --project=dom-contract --headed",
    "test:a11y": "playwright test -c playwright.a11y.config.js",
    "test:visual": "playwright test -c playwright.visual.config.js",
    "test:visual:update": "playwright test -c playwright.visual.config.js --update-snapshots",
    "test:mobile-webkit": "playwright test -c playwright.mobile-webkit.config.js",
    "build": "vite build && node scripts/copy-static-assets.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "preview": "vite --host 127.0.0.1 --port 9876"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.0.0",
    "@fontsource-variable/archivo": "^5.3.0",
    "@fontsource/barlow-condensed": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
